# Required API Keys
PINECONE_API_KEY=your-pinecone-api-key
VOYAGE_API_KEY=your-voyage-api-key

# LLM Provider — set ONE of these (Groq recommended for speed):
GROQ_API_KEY=your-groq-api-key
# XAI_API_KEY=your-xai-api-key
# ANTHROPIC_API_KEY=your-anthropic-api-key
# GOOGLE_API_KEY=your-google-api-key  # Future: Gemini models

# Pinecone Configuration
PINECONE_INDEX_NAME=legacylens

# Model Configuration
EMBEDDING_MODEL=voyage-code-3
EMBEDDING_DIMENSION=1024
LLM_MODEL=llama-3.3-70b-versatile
# LLM_API_BASE=        # Auto-detected from API key if not set
# LLM_CONTEXT_WINDOW=131072

# Retrieval Configuration
TOP_K=5

# Codebase Path (relative to project root)
CODEBASE_PATH=codebase/gnucobol
